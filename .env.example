# App & Security
NEXT_PUBLIC_APP_URL=https://your-tunnel-url.trycloudflare.com
SESSION_SECRET=generate-a-long-random-string-here-64chars-min
PLEX_SERVER_URL=http://localhost:32400

# TMDB
TMDB_API_KEY=your-tmdb-api-key

# Admin access: comma-separated list of Plex user IDs (numeric). Find yours at
# https://app.plex.tv/desktop after logging in — it's in the URL: /users/<id>/...
ADMIN_PLEX_IDS=
# Plex Media Server (for library availability checks)
PLEX_SERVER_TOKEN=your-plex-server-token

# Radarr instances (for request status checks)
RADARR_1_URL=http://localhost:7878
RADARR_1_API_KEY=your-radarr-api-key
RADARR_2_URL=http://localhost:7879
RADARR_2_API_KEY=your-radarr-api-key
RADARR_3_URL=http://localhost:7880
RADARR_3_API_KEY=your-radarr-api-key

# Sonarr instances (for request status checks)
SONARR_1_URL=http://localhost:8989
SONARR_1_API_KEY=your-sonarr-api-key
SONARR_2_URL=http://localhost:8990
SONARR_2_API_KEY=your-sonarr-api-key
SONARR_3_URL=http://localhost:8991
SONARR_3_API_KEY=your-sonarr-api-key

# Server-side Plex client identifier (used for the PIN login request, separate
# from the NEXT_PUBLIC_ version used in the browser)
PLEX_CLIENT_ID=plexpulse-client-id

# Automatic Plex library scan interval in hours (default: 24). Set to 0 to disable.
SCAN_SCHEDULE_HOURS=24

# Database & Cache
DATABASE_URL=./data/plexpulse.db
REDIS_PASSWORD=change-this-to-a-random-password-openssl-rand-hex-32
# NOTE for Unraid template users: the ${} syntax only works in docker-compose env_file.
# In Unraid's template UI, hardcode the full URL without variable expansion:
# REDIS_URL=redis://:<your-pasWORD>@<host>:<port>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# HTTPS Configuration
# Set to true only when running behind HTTPS (like a Cloudflare Tunnel)
IS_HTTPS=false
